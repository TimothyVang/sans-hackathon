{
  "name": "@findevil/web",
  "version": "0.1.0",
  "private": true,
  "description": "Find Evil! NES.css live dashboard — Phase 4 of Amendment A3 (apps/web/ un-deferral). Scaffold only; sprite components + audit-log live tail land in follow-up PRs.",
  "scripts": {
    "dev": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "codegen:events": "uv run --directory ../../services/agent python ../../scripts/codegen-events.py"
  },
  "dependencies": {
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "nes.css": "^2.3.0",
    "chokidar": "^4.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "json-schema-to-typescript": "^14.1.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
