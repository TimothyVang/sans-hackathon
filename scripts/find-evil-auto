#!/usr/bin/env bash
# find-evil-auto — Tesla-mode investigation orchestrator (single-command).
#
# Pre-flight: SIFT VM running + scripts/sift-vm-bootstrap.sh has been run.
#
# Usage:
#   bash scripts/find-evil-auto <evidence-path-inside-VM> [--unattended] [--no-report] [--run-summary <path>]
#
# Examples:
#   bash scripts/find-evil-auto /mnt/hgfs/evidence/extracted/base-dc/base-dc-memory.img
#   bash scripts/find-evil-auto /mnt/hgfs/evidence/single-evtx/Security.evtx --unattended
#   bash scripts/find-evil-auto /mnt/hgfs/evidence/cases/base-dc/ --unattended
#   bash scripts/find-evil-auto /mnt/hgfs/evidence/velociraptor/base-dc.zip --unattended
#
# What it does end-to-end (no human input required after launch):
#   1. case_open (real SHA-256 of evidence)
#   2. Detect evidence type → run playbook tool sequence
#      (memory: vol_pslist + vol_psscan + vol_malfind for DKOM
#       cross-validation; evtx: evtx_query; disk: read-only mount/extract
#       where supported; directory: inventory + per-artifact dispatch;
#       Velociraptor zip: safe extract + per-artifact dispatch)
#   3. Synthesize Pool A/B Findings deterministically from tool outputs
#   4. detect_contradictions → judge_findings → correlate_findings
#   5. Emit 6 kind=judge_selfscore audit records (per agent-config/JUDGING.md)
#      BEFORE manifest_finalize so the score is part of the cryptographic
#      attestation
#   6. manifest_finalize (Merkle + sigstore)
#   7. Write verdict.json
#   8. Generate PDF report (matplotlib + pandoc + Chrome headless;
#      surfaces the selfscore table in the per-case REPORT.pdf)
#
# Output (inside VM):
#   /home/sansforensics/find-evil/tmp/auto-<uuid>/
#     audit.jsonl, run.manifest.json, verdict.json
# Output (on host):
#   tmp/auto-runs/auto-<uuid>/
#     audit.jsonl, run.manifest.json, verdict.json,
#     REPORT.md, REPORT.html, REPORT.pdf, figures/*.png
# Optional --run-summary writes a host-side machine-readable JSON summary.

set -euo pipefail

# Git Bash on Windows otherwise rewrites the evidence path
# /home/sansforensics/... → C:/Program Files/Git/home/sansforensics/...
# when calling a Windows-native python.exe. The evidence path is meant
# to live INSIDE the SIFT VM; we never want it touched.
export MSYS_NO_PATHCONV=1
export MSYS2_ARG_CONV_EXCL='*'

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SCRIPT="${REPO_ROOT}/scripts/find_evil_auto.py"
# python.exe is a Windows binary; the script path needs to be Windows-native
# OR we lose by setting MSYS_NO_PATHCONV. cygpath -w converts cleanly.
if command -v cygpath >/dev/null 2>&1; then
  SCRIPT="$(cygpath -w "$SCRIPT")"
fi
exec python "$SCRIPT" "$@"
