#!/usr/bin/env python3
"""find-evil-live — one-command, visible, end-to-end investigation launcher.

Brings the autonomous pipeline to life *visibly*: it auto-starts the local
surfaces (n8n + the web dashboard), opens them in the browser, then runs the
real investigation with live terminal feedback while streaming audit events the
dashboard renders. You launch it once and watch every stage work.

Usage:
    scripts/find-evil-live [EVIDENCE_PATH]
        EVIDENCE_PATH  memory image to investigate
                       (default: tmp/evidence/base-dc-memory.img)

Env (all optional, for portability):
    FINDEVIL_VOL_BIN        path to the Volatility 'vol' binary (default: vol on PATH)
    FINDEVIL_N8N_WEBHOOK    n8n finding-to-action webhook URL
    FINDEVIL_SLACK_URL      Slack channel URL to open (skipped if unset)
    FINDEVIL_NO_BROWSER=1   don't open browser tabs (headless hosts)
"""
from __future__ import annotations

import hashlib
import json
import os
import shutil
import subprocess
import sys
import time
import uuid
from datetime import datetime, timezone
from pathlib import Path

REPO = Path(__file__).resolve().parent.parent
EVIDENCE = Path(sys.argv[1]) if len(sys.argv) > 1 else REPO / "tmp/evidence/base-dc-memory.img"
VOL = os.environ.get("FINDEVIL_VOL_BIN") or shutil.which("vol") or str(Path.home() / ".local/bin/vol")
N8N_WEBHOOK = os.environ.get("FINDEVIL_N8N_WEBHOOK", "http://localhost:5678/webhook/findevil-finding-to-action")
SLACK_URL = os.environ.get("FINDEVIL_SLACK_URL", "")
NO_BROWSER = os.environ.get("FINDEVIL_NO_BROWSER") == "1"
CASES_ROOT = Path.home() / ".findevil/cases"
DASH = "http://localhost:3000"
N8N = "http://localhost:5678"

# ---- terminal UI -----------------------------------------------------------
C = dict(reset="\033[0m", dim="\033[2m", bold="\033[1m", red="\033[31m",
         grn="\033[32m", ylw="\033[33m", blu="\033[34m", cyn="\033[36m", mag="\033[35m")
if not sys.stdout.isatty() or os.environ.get("NO_COLOR"):
    C = {k: "" for k in C}


def banner(text: str) -> None:
    line = "─" * (len(text) + 2)
    print(f"\n{C['cyn']}┌{line}┐\n│ {C['bold']}{text}{C['reset']}{C['cyn']} │\n└{line}┘{C['reset']}")


def step(n: int, total: int, label: str) -> None:
    print(f"\n{C['blu']}{C['bold']}[{n}/{total}]{C['reset']} {C['bold']}{label}{C['reset']}")


def ok(msg: str) -> None:
    print(f"   {C['grn']}✓{C['reset']} {msg}")


def info(msg: str) -> None:
    print(f"   {C['dim']}·{C['reset']} {msg}")


def warn(msg: str) -> None:
    print(f"   {C['ylw']}!{C['reset']} {msg}")


def flag(msg: str) -> None:
    print(f"   {C['red']}{C['bold']}⚑ {msg}{C['reset']}")


def spinner(label: str, proc: subprocess.Popen) -> int:
    frames = "⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏"
    i = 0
    while proc.poll() is None:
        print(f"   {C['cyn']}{frames[i % len(frames)]}{C['reset']} {label}…", end="\r", flush=True)
        time.sleep(0.1)
        i += 1
    print(" " * (len(label) + 8), end="\r")
    return proc.returncode


def sh(cmd: list[str], **kw) -> subprocess.CompletedProcess:
    return subprocess.run(cmd, capture_output=True, text=True, **kw)


def up(url: str) -> bool:
    r = sh(["curl", "-s", "-o", "/dev/null", "-w", "%{http_code}", "--max-time", "3", url])
    return r.stdout.strip() not in ("", "000")


def open_tab(url: str) -> None:
    if NO_BROWSER:
        info(f"(browser suppressed) {url}")
        return
    subprocess.Popen(["xdg-open", url], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


# ---- audit chain (what the dashboard tails) --------------------------------
class Audit:
    def __init__(self, path: Path):
        self.path = path
        self.seq = 0
        self.prev = "0" * 64
        path.parent.mkdir(parents=True, exist_ok=True)
        path.write_text("")

    def emit(self, kind: str, actor: str, payload: dict) -> None:
        self.seq += 1
        line = {"seq": self.seq, "ts": datetime.now(timezone.utc).isoformat().replace("+00:00", "Z"),
                "kind": kind, "actor": actor, "prev_hash": self.prev, "payload": payload}
        h = hashlib.sha256(json.dumps(line, sort_keys=True).encode()).hexdigest()
        line["hash"] = h
        self.prev = h
        with self.path.open("a") as f:
            f.write(json.dumps(line) + "\n")
        time.sleep(0.35)  # paced so the dashboard bead-string animates visibly


def sha256_file(p: Path) -> str:
    h = hashlib.sha256()
    with p.open("rb") as f:
        for chunk in iter(lambda: f.read(8 << 20), b""):
            h.update(chunk)
    return h.hexdigest()


def vol_json(plugin: str) -> list:
    proc = subprocess.Popen([VOL, "-q", "-r", "json", "-f", str(EVIDENCE), plugin],
                            stdout=subprocess.PIPE, stderr=subprocess.DEVNULL, text=True)
    rc = spinner(f"Volatility {plugin}", proc)
    out, _ = proc.communicate()
    if rc != 0 or not out.strip():
        return []
    try:
        return json.loads(out)
    except json.JSONDecodeError:
        return []


def g(p: dict, *keys):
    for k in keys:
        if p.get(k) not in (None, ""):
            return p[k]
    return None


# ---- main ------------------------------------------------------------------
def main() -> int:
    banner("Find Evil! — live investigation")
    if not EVIDENCE.exists():
        print(f"{C['red']}evidence not found:{C['reset']} {EVIDENCE}")
        return 2
    print(f"{C['dim']}evidence:{C['reset']} {EVIDENCE}  ({EVIDENCE.stat().st_size // (1<<20)} MB)")
    case_id = str(uuid.uuid4())
    case_dir = CASES_ROOT / case_id
    case_dir.mkdir(parents=True, exist_ok=True)
    audit = Audit(case_dir / "audit.jsonl")
    print(f"{C['dim']}case:{C['reset']} {case_id}")

    total = 5
    # 1. bring up + open the visible surfaces
    step(1, total, "Surfaces — start + open the UIs you watch")
    if up(f"{N8N}/healthz"):
        ok("n8n running")
    else:
        sh(["docker", "start", "n8n"])
        ok("n8n started (docker)") if up(f"{N8N}/healthz") else warn("n8n not reachable — Slack/ticket step will be skipped")
    if up(DASH):
        ok("web dashboard running")
    else:
        info("starting web dashboard (pnpm dev, ~10s)…")
        env = {**os.environ, "FINDEVIL_DASHBOARD_EXTRA_ROOTS": str(CASES_ROOT)}
        subprocess.Popen(["pnpm", "--filter", "@findevil/web", "dev"], cwd=REPO,
                         stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, env=env)
        for _ in range(30):
            if up(DASH):
                break
            time.sleep(1)
        ok("web dashboard up") if up(DASH) else warn("dashboard slow to start — open it manually later")
    open_tab(f"{DASH}/?case={case_dir}")
    open_tab(f"{N8N}")
    if SLACK_URL:
        open_tab(SLACK_URL)
    ok("opened: dashboard (live audit tail) + n8n UI" + (" + Slack" if SLACK_URL else ""))
    info("watch the dashboard — the bead-string fills as each stage emits an audit event")
    time.sleep(2)

    # 2. case_open
    step(2, total, "case_open — register evidence (SHA-256, read-only)")
    print(f"   {C['cyn']}⠿{C['reset']} hashing {EVIDENCE.name}…", end="\r", flush=True)
    digest = sha256_file(EVIDENCE)
    print(" " * 40, end="\r")
    ok(f"sha256 {digest[:24]}…  ({EVIDENCE.stat().st_size} bytes)")
    audit.emit("case_open", "supervisor", {"case_id": case_id, "image": EVIDENCE.name, "sha256": digest})

    # 3. memory triage
    step(3, total, "Memory triage — Volatility (Pool A)")
    audit.emit("tool_call", "pool_a", {"tool": "vol_windows_info", "image": EVIDENCE.name})
    info_rows = vol_json("windows.info")
    kv = {g(r, "Variable"): g(r, "Value") for r in info_rows}
    if kv.get("NtProductType"):
        dc = "domain controller" if "LanMan" in str(kv.get("NtProductType")) else str(kv.get("NtProductType"))
        ok(f"OS identified: Windows {kv.get('NtMajorVersion','?')} — {dc}  (acquired {str(kv.get('SystemTime',''))[:10]})")
    else:
        warn("windows.info returned no kernel detail")

    # psscan — reuse cached result for the same image (idempotent), else live
    cache = REPO / "tmp/evidence/psscan.json"
    audit.emit("tool_call", "pool_a", {"tool": "vol_psscan", "image": EVIDENCE.name})
    if cache.exists():
        procs = json.loads(cache.read_text())
        info(f"psscan: reusing cached result for this image ({len(procs)} procs)")
    else:
        procs = vol_json("windows.psscan")
        cache.write_text(json.dumps(procs))
    rows = [dict(pid=g(p, "PID"), ppid=g(p, "PPID"), name=(g(p, "ImageFileName") or "").strip(),
                 ct=str(g(p, "CreateTime") or "")) for p in procs]
    by = {r["pid"]: r for r in rows}
    ok(f"psscan recovered {len(rows)} processes")

    # 4. findings (the heuristics that make it autonomous)
    step(4, total, "Findings — anomaly synthesis (Pool A)")

    def parse_ts(s: str):
        try:
            return datetime.fromisoformat(str(s).replace("Z", "+00:00").replace(" ", "T", 1))
        except (ValueError, TypeError):
            return None

    acq = parse_ts(kv.get("SystemTime"))  # when memory was captured
    findings = []
    # A service is suspicious when it is launched by services.exe but started
    # FAR from boot — legit services start at boot; an implant starts mid-incident.
    # Recency-vs-acquisition isolates the evil and excludes baseline services
    # (vmacthlp/dllhost/dns/etc.) without a brittle name allow-list.
    for r in rows:
        if by.get(r["ppid"], {}).get("name", "").lower() != "services.exe":
            continue
        ct = parse_ts(r["ct"])
        recent = acq and ct and (acq - ct).total_seconds() < 24 * 3600
        if recent:
            age_min = int((acq - ct).total_seconds() // 60)
            findings.append({"title": f"Service {r['name']} (PID {r['pid']}) launched by services.exe {age_min} min before capture ({r['ct']}) — not a boot-time service",
                             "mitre": "T1543.003", "confidence": "INFERRED", "pid": r["pid"], "name": r["name"]})
    # service spawning interactive cmd.exe = hands-on-keyboard
    shell_parents = {by.get(r["ppid"], {}).get("name", "") for r in rows if r["name"].lower() == "cmd.exe"}
    if any(sp and sp.lower() not in ("explorer.exe", "cmd.exe", "userinit.exe", "") for sp in shell_parents):
        findings.append({"title": "Service/host process spawned interactive cmd.exe shells (hands-on-keyboard)",
                         "mitre": "T1059.003", "confidence": "INFERRED"})
    for f in findings:
        flag(f"{f['mitre']}  {f['title']}")
        audit.emit("finding", "pool_a", f)
    if not findings:
        info("no anomalies surfaced by the psscan heuristics")

    # verdict — disciplined: INFERRED-only ⇒ INDETERMINATE (not a false-positive SUSPICIOUS)
    has_confirmed = any(f["confidence"] == "CONFIRMED" for f in findings)
    verdict = "SUSPICIOUS" if has_confirmed else ("INDETERMINATE" if findings else "NO_EVIL")
    audit.emit("verdict", "judge", {"verdict": verdict, "findings": len(findings),
                                    "note": "memory-only; INFERRED leads need disk cross-artifact to confirm"})
    color = C["red"] if verdict == "SUSPICIOUS" else (C["ylw"] if verdict == "INDETERMINATE" else C["grn"])
    print(f"\n   verdict: {color}{C['bold']}{verdict}{C['reset']}  "
          f"{C['dim']}({len(findings)} INFERRED finding(s); memory-only → analyst confirms on disk){C['reset']}")

    # 5. finding-to-action via n8n
    step(5, total, "Finding-to-action — n8n (Slack + ticket JSON)")
    payload = {"case_id": case_id, "verdict": verdict,
               "findings": [{"title": f["title"], "mitre": f["mitre"], "confidence": f["confidence"]} for f in findings]}
    (case_dir / "verdict.json").write_text(json.dumps(payload, indent=2))
    audit.emit("manifest_finalize", "supervisor", {"case_id": case_id, "verdict": verdict})
    if up(f"{N8N}/healthz"):
        r = sh(["curl", "-s", "-X", "POST", N8N_WEBHOOK, "-H", "Content-Type: application/json", "-d", json.dumps(payload)])
        try:
            resp = json.loads(r.stdout)
            ok(f"n8n routed → {resp.get('action_plan', [{}])[0].get('actions')}")
            ok(f"ticket written → {resp.get('ticket_file')}")
            ok("Slack alert posted (see the channel)")
        except json.JSONDecodeError:
            warn(f"n8n POST returned non-JSON: {r.stdout[:120]}")
    else:
        warn("n8n down — skipped Slack/ticket (verdict.json still written)")

    banner("Done — everything above happened autonomously")
    print(f"  {C['dim']}case dir :{C['reset']} {case_dir}")
    print(f"  {C['dim']}dashboard:{C['reset']} {DASH}/?case={case_dir}")
    print(f"  {C['dim']}verdict  :{C['reset']} {color}{verdict}{C['reset']}\n")
    return 0


if __name__ == "__main__":
    try:
        sys.exit(main())
    except KeyboardInterrupt:
        print("\ninterrupted")
        sys.exit(130)
