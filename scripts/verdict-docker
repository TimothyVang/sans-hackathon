#!/usr/bin/env bash
# scripts/verdict-docker — run a VERDICT investigation inside the reproducible
# runner container (docker/verdict-runner.Dockerfile). Evidence goes in
# read-only; the signed run + audit.jsonl persist to ./out/ on the host.
#
#   bash scripts/verdict-docker <evidence-path> [--build]
#
# Credentials (one of, auto-detected): CLAUDE_CODE_OAUTH_TOKEN, ANTHROPIC_API_KEY,
# or a populated ~/.claude (mounted read-only). Fails closed if none are present.
# Set ANTHROPIC_MODEL to pin the Claude model id for run-to-run consistency.
#
# See docs/runbooks/docker-runner.md for the full story (and the determinism
# caveat: containers pin the ENVIRONMENT, not the LLM's wording).
set -euo pipefail

REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
IMAGE="verdict-runner:local"
DOCKERFILE="${REPO}/docker/verdict-runner.Dockerfile"

usage() {
  echo "usage: bash scripts/verdict-docker <evidence-path> [--headless] [--build]" >&2
  echo "  --headless   run the deterministic engine (find_evil_auto.py) — no Claude token needed" >&2
  exit 2
}

EVIDENCE=""
FORCE_BUILD=0
HEADLESS=0
for arg in "$@"; do
  case "${arg}" in
    --build)    FORCE_BUILD=1 ;;
    --headless) HEADLESS=1 ;;
    -h|--help)  usage ;;
    -*)         echo "unknown flag: ${arg}" >&2; usage ;;
    *)          EVIDENCE="${arg}" ;;
  esac
done
[ -n "${EVIDENCE}" ] || usage
[ -e "${EVIDENCE}" ] || { echo "[verdict-docker] evidence not found: ${EVIDENCE}" >&2; exit 1; }

command -v docker >/dev/null 2>&1 || {
  echo "[verdict-docker] docker is not installed or not on PATH." >&2
  exit 1
}

# Build the image if it is missing or a rebuild was requested.
if [ "${FORCE_BUILD}" -eq 1 ] || ! docker image inspect "${IMAGE}" >/dev/null 2>&1; then
  echo "[verdict-docker] building ${IMAGE} (first build downloads the DFIR toolchain — several minutes)..."
  docker build -f "${DOCKERFILE}" -t "${IMAGE}" "${REPO}"
fi

# Credential handling. The interactive path is a real Claude session, so it
# requires a credential (fail closed). The --headless path runs the deterministic
# engine (find_evil_auto.py), which never calls the LLM — so no token is needed.
run_args=()
if [ "${HEADLESS}" -eq 0 ]; then
  if [ -n "${CLAUDE_CODE_OAUTH_TOKEN:-}" ]; then
    run_args+=(-e CLAUDE_CODE_OAUTH_TOKEN)
  elif [ -n "${ANTHROPIC_API_KEY:-}" ]; then
    run_args+=(-e ANTHROPIC_API_KEY)
  elif [ -d "${HOME}/.claude" ]; then
    run_args+=(-v "${HOME}/.claude:/home/verdict/.claude:ro")
  else
    echo "[verdict-docker] no credentials found. Set CLAUDE_CODE_OAUTH_TOKEN or" >&2
    echo "  ANTHROPIC_API_KEY, or run 'claude auth login' to populate ~/.claude." >&2
    echo "  (Or use --headless to run the deterministic engine with no token.)" >&2
    exit 1
  fi
  [ -n "${ANTHROPIC_MODEL:-}" ] && run_args+=(-e ANTHROPIC_MODEL)
fi

# Output dir must exist and be owned by the host user so the in-image uid-1000
# `verdict` user can write the run there.
mkdir -p "${REPO}/out"

# Absolute evidence path for the read-only bind mount. Preserve the ORIGINAL
# filename inside the container so the engine can detect the evidence type by
# extension (.img/.mem/.E01/.evtx/.pcap/...). A fixed name like /evidence/case
# strips the extension and reads as "unknown type" -> zero findings.
ev_dir="$(cd "$(dirname "${EVIDENCE}")" && pwd)"
ev_base="$(basename "${EVIDENCE}")"
ev_abs="${ev_dir}/${ev_base}"
container_ev="/evidence/${ev_base}"

echo "[verdict-docker] evidence (ro): ${ev_abs}  ->  ${container_ev}"
echo "[verdict-docker] output  (rw): ${REPO}/out"

if [ "${HEADLESS}" -eq 1 ]; then
  # Deterministic engine: runs the per-evidence playbook over the typed MCP tools
  # and synthesizes findings by rule — no Claude token, --unattended so it never
  # pauses for analyst input. Run through the agent_mcp uv env (it carries the
  # engine's deps, e.g. pydantic; bare python3 in the image does not). The run +
  # JSON summary land under ./out/ on the host (REPO_ROOT/tmp is the mount).
  echo "[verdict-docker] mode: headless (deterministic engine, no token)"
  exec docker run --rm \
    -v "${ev_abs}:${container_ev}:ro" \
    -v "${REPO}/out:/workspace/tmp:rw" \
    -e FIND_EVIL_LOCAL=1 \
    -e EV_PATH="${container_ev}" \
    "${IMAGE}" \
    bash -lc 'exec uv run --directory /workspace/services/agent_mcp python /workspace/scripts/find_evil_auto.py "$EV_PATH" --local --unattended --run-summary /workspace/tmp/verdict-headless-summary.json'
fi

# Interactive: a real Claude Code session inside the container.
exec docker run --rm -it \
  -v "${ev_abs}:${container_ev}:ro" \
  -v "${REPO}/out:/workspace/tmp:rw" \
  -e EV_PATH="${container_ev}" \
  "${run_args[@]}" \
  "${IMAGE}" \
  bash -lc 'printf "\n  VERDICT runner ready.\n  Evidence mounted read-only at %s\n  Output persists to ./out/ on your host.\n\n  Starting Claude Code — then type:  investigate %s\n\n" "$EV_PATH" "$EV_PATH"; exec claude'
