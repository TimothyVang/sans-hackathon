# Large binaries / evidence / VMs
*.ova
*.qcow2
*.vmdk
*.vdi
*.E01
*.e01
*.dd
*.raw
*.mem
*.aff
*.aff4
*.vhd
*.vhdx
# Windows event logs — fixture-only; never commit (real EVTX contains
# logon history, hostnames, GUIDs and other user-identifying data).
*.evtx
*.EVTX

# Rust
target/
**/*.rs.bk
# Cargo.lock IS committed — this is an application workspace with
# a shipped binary (findevil-mcp), not a library. See Rust book
# §"Cargo and Cargo.lock" for the convention.

# Python
__pycache__/
*.py[cod]
*$py.class
.Python
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Node / Next.js
node_modules/
.next/
out/
dist/
.turbo/

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp

# Env
.env
.env.local
.env.*.local

# Claude
.claude-cache/

# Build artifacts
/build/
/dist/

# Logs
*.log

# Local state
/state/
/checkpoints/
*.sqlite
*.sqlite-journal

# External reference clones (research-only, never ship in submission)
/openclaw/
/hermes-agent/
/Linear-Coding-Agent-Harness/
/.playwright-mcp/
# The same reference clones, now relocated under ref-folders/ —
# also research-only, also never shipped, and ruff should not scan
# them.
/ref-folders/

# Smoke test working dir (Amendment A2) — produces audit logs +
# manifests under tmp/smoke/ that should never be committed.
/tmp/
